# Zenfocus Gitea - Environment Configuration
# Copie este arquivo para .env e ajuste os valores conforme necessario

# DNS Configuration
DNS_PORT=1053
WEBMIN_ENABLED=false

# Gitea Configuration
GITEA_DOMAIN=gitea.zenfocus.com
GITEA_SSH_PORT=2222

# Proxy Configuration
PROXY_HTTP_PORT=80
PROXY_HTTPS_PORT=443

# Application Configuration
APP_DOMAIN=www.zenfocus.com
APP_PORT=8080

# Database Configuration
MARIADB_ROOT_PASSWORD=root123
MARIADB_DATABASE=zenfocus
MARIADB_USER=zenfocus
MARIADB_PASSWORD=zenfocus123
MARIADB_GITEA_DATABASE=gitea
MARIADB_GITEA_USER=gitea
MARIADB_GITEA_PASSWORD=gitea123

# Network Configuration
NETWORK_NAME=zenfocus-gitea-net
