# Zenfocus Gitea - Environment Configuration
# Copie este arquivo para .env e ajuste os valores conforme necessario

# DNS Configuration
DNS_PORT=1053
WEBMIN_ENABLED=false

# Gitea Configuration
GITEA_DOMAIN=gitea.zenfocus.com
GITEA_SSH_PORT=2222

# Proxy Configuration
PROXY_HTTP_PORT=80
PROXY_HTTPS_PORT=443

# Application Configuration
APP_DOMAIN=www.zenfocus.com
APP_PORT=8080

# Database Configuration
MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=zenfocus
MYSQL_USER=zenfocus
MYSQL_PASSWORD=zenfocus123
MYSQL_GITEA_DATABASE=gitea
MYSQL_GITEA_USER=gitea
MYSQL_GITEA_PASSWORD=gitea123

# Network Configuration
NETWORK_NAME=zenfocus-gitea-net
