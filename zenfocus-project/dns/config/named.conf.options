options {
    directory "/var/cache/bind";

    // Aceitar consultas de qualquer origem
    allow-query { any; };
    
    // Desabilitar recursão para servidor autoritativo
    recursion no;
    
    // Escutar em todas as interfaces
    listen-on { any; };
    listen-on-v6 { any; };

    // DNS forwarders (opcional, para consultas externas)
    forwarders {
        8.8.8.8;
        8.8.4.4;
    };

    dnssec-validation auto;

    auth-nxdomain no;    # conform to RFC1035
};
