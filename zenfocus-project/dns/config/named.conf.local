//
// Configuração de zonas locais para zenfocus.com.br
//

zone "zenfocus.com.br" {
    type master;
    file "/etc/bind/db.zenfocus.com.br";
    allow-query { any; };
    allow-transfer { none; };
};

// Zona reversa (opcional)
zone "59.164.10.in-addr.arpa" {
    type master;
    file "/etc/bind/db.10.164.59";
    allow-query { any; };
};
